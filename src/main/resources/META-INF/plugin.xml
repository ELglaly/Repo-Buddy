<!-- Plugin Configuration File. Read more: https://plugins.jetbrains.com/docs/intellij/plugin-configuration-file.html -->
<idea-plugin>
    <!-- Unique identifier of the plugin. It should be FQN. It cannot be changed between the plugin versions. -->
    <id>com.elglaly.repobuddy</id>

    <!-- Public plugin name should be written in Title Case.
         Guidelines: https://plugins.jetbrains.com/docs/marketplace/plugin-overview-page.html#plugin-name -->
    <name>RepoBuddy</name>

    <!-- A displayed Vendor name or Organization ID displayed on the Plugins Page. -->
    <vendor email="sherifelglaly@gmail.com" url="https://elglaly.github.io/Sherif-Elglaly/">Sherif Elglaly</vendor>

    <!-- Product and plugin compatibility requirements.
         Read more: https://plugins.jetbrains.com/docs/intellij/plugin-compatibility.html -->
    <depends>com.intellij.modules.platform</depends>
    <depends>com.intellij.modules.java</depends>

    <!-- Extension points defined by the plugin.
         Read more: https://plugins.jetbrains.com/docs/intellij/plugin-extension-points.html -->
    <extensions defaultExtensionNs="com.intellij">

        <projectService
                serviceInterface="com.repoinspector.analysis.api.RepositoryAnalysisService"
                serviceImplementation="com.repoinspector.analysis.impl.DefaultRepositoryAnalysisService"/>
        <projectService
                serviceInterface="com.repoinspector.analysis.api.EndpointAnalysisService"
                serviceImplementation="com.repoinspector.analysis.impl.DefaultEndpointAnalysisService"/>
        <projectService
                serviceInterface="com.repoinspector.analysis.api.CallChainService"
                serviceImplementation="com.repoinspector.analysis.impl.DefaultCallChainService"/>
        <applicationService
                serviceInterface="com.repoinspector.runner.service.api.ParameterExtractionService"
                serviceImplementation="com.repoinspector.runner.service.impl.DefaultParameterExtractionService"/>

        <applicationService
                serviceInterface="com.repoinspector.analysis.api.OperationClassifierService"
                serviceImplementation="com.repoinspector.analysis.impl.DefaultOperationClassifierService"/>

        <codeInsight.lineMarkerProvider
                language="JAVA"
                implementationClass="com.repoinspector.gutter.RepoMethodGutterProvider"/>

        <toolWindow id="RepoBuddy"
                    anchor="bottom"
                    factoryClass="com.repoinspector.ui.RepoInspectorToolWindowFactory"/>

        <postStartupActivity
                implementation="com.repoinspector.runner.startup.AgentRunConfigPatcher"/>

        <notificationGroup id="RepoBuddy Notifications"
                           displayType="BALLOON"
                           toolWindowId="Event Log"/>

    </extensions>

    <actions>
        <action id="RepoBuddy.TraceRepositoryCalls"
                class="com.repoinspector.actions.TraceRepositoryCallsAction"
                text="Trace Repository Calls for This API"
                description="Trace all repository methods reachable from this Spring endpoint">
            <add-to-group group-id="EditorPopupMenu" anchor="last"/>
        </action>
    </actions>

</idea-plugin>
